{
  "manifest_version": 3,
  "name": "EloVision",
  "version": "2.0.0",
  "description": "EloVision V2: statistiche dell'avversario su chess.com, WLR, peak ELO e strumenti di analisi.",
  "permissions": [
    "activeTab",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://api.chess.com/*",
    "https://stockfish.online/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*"
      ],
      "js": [
        "modules/stats-cheater.js",
        "modules/game-insights.js",
        "modules/post-game-coach.js",
        "modules/human-automove.js",
        "modules/game-flow.js",
        "modules/core-main.js",
        "modules/eval-tools.js",
        "modules/auto-modules.js",
        "modules/tools-gui.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "modules/stockfish/*",
        "modules/maia/*",
        "modules/maia/weights/*"
      ],
      "matches": [
        "https://www.chess.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  }
}
