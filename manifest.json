{
  "manifest_version": 3,
  "name": "Chess.com Opponent Stats",
  "version": "1.0.0",
  "description": "Mostra le statistiche dell'avversario su chess.com: win/lose in 1, 7, 30 giorni, WLR e peak ELO.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://api.chess.com/*",
    "https://stockfish.online/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": [
        "modules/stats-cheater.js",
        "modules/game-insights.js",
        "modules/core-main.js",
        "modules/eval-tools.js",
        "modules/auto-modules.js",
        "modules/tools-gui.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["modules/stockfish/*"],
      "matches": ["https://www.chess.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
